# Database (see docker-compose.yml)
DATABASE_URL="postgresql://altcoinlog:altcoinlog@localhost:5432/altcoinlog"

# Auth.js — generate: openssl rand -base64 32
AUTH_SECRET="change-me-in-production"
AUTH_TRUST_HOST="true"

# Public site URL (SEO, absolute links in RSS)
NEXT_PUBLIC_SITE_URL="http://localhost:3000"

# Optional: OpenAI for AI-assisted drafts from ingestion items
# OPENAI_API_KEY=""

# Optional: protect ingestion cron with a secret header
# INGESTION_CRON_SECRET=""

# Optional: override default seed password (default: changeme)
# SEED_ADMIN_PASSWORD=""
